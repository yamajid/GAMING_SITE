# Gaming Coins Hub - Automation Configuration
# Copy this file to .env.automation and fill in your actual values
# DO NOT commit .env.automation to version control!

# ==============================================================================
# REQUIRED: Reddit API (for scraping codes and questions)
# Get these from: https://www.reddit.com/prefs/apps/
# ==============================================================================
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# ==============================================================================
# REQUIRED: GitHub API (for auto-publishing content)
# Get token from: https://github.com/settings/tokens
# Required scopes: repo (full control of private repositories)
# ==============================================================================
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_OWNER=your-github-username
GITHUB_REPO=gaming-coins-hub

# ==============================================================================
# OPTIONAL: Claude API (for AI content generation)
# Get key from: https://console.anthropic.com/
# If not provided, falls back to template generation
# ==============================================================================
CLAUDE_API_KEY=sk-ant-your_claude_api_key_here

# ==============================================================================
# OPTIONAL: Vercel API (for automatic deployment after publishing)
# Get token from: https://vercel.com/account/tokens
# Get project ID from: Vercel dashboard project settings
# ==============================================================================
VERCEL_TOKEN=your_vercel_token_here
VERCEL_PROJECT_ID=your_vercel_project_id
VERCEL_WEBHOOK=https://api.vercel.com/v1/integrations/deploy/your_webhook_id

# ==============================================================================
# AUTOMATION SCHEDULE: Cron format (minute hour day month day-of-week)
# Default: "0 2 * * *" = 2:00 AM UTC every day
# Other examples:
#   "0 */6 * * *" = Every 6 hours
#   "0 0 * * 1" = Every Monday
#   "0 8 * * *" = 8:00 AM UTC every day
# ==============================================================================
AUTOMATION_SCHEDULE=0 2 * * *

# ==============================================================================
# OPTIONAL: Notification Webhooks (for alerting on success/failure)
# ==============================================================================
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL
EMAIL_WEBHOOK=https://your-email-service.com/webhook

# ==============================================================================
# DEBUG & DRY RUN MODE
# ==============================================================================
# DEBUG: Set to 'true' for verbose logging
DEBUG=false

# DRY_RUN: Set to 'true' to test without making actual commits
# Useful for testing scraper and generator without GitHub changes
DRY_RUN=false
