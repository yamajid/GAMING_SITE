# Gaming Coins Hub - Automation Environment Configuration
# Copy this file to .env.automation and fill in your actual values
# .env.automation is in .gitignore - NEVER commit with real secrets

# =============================================================================
# CRITICAL CREDENTIALS (Must have)
# =============================================================================

# GitHub Personal Access Token (with repo write access)
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=github_pat_your_token_here

# =============================================================================
# AI & CONTENT ENHANCEMENT (Recommended)
# =============================================================================

# Claude API Key (for AI-powered content generation)
# Get from: https://console.anthropic.com/
# Cost: ~$0.15-0.30 per day (optional, has fallback templates)
CLAUDE_API_KEY=sk-ant-your-claude-api-key-here

# =============================================================================
# AUTOMATION SCHEDULE
# =============================================================================

# Cron format: "minute hour day-of-month month day-of-week"
# Default: 2 AM UTC daily
# Examples:
#   "0 2 * * *" = Every day at 2:00 AM UTC
#   "0 2 * * 1" = Every Monday at 2:00 AM UTC
#   "0 */4 * * *" = Every 4 hours
AUTOMATION_SCHEDULE=0 2 * * *

# =============================================================================
# GITHUB CONFIGURATION
# =============================================================================

# Your GitHub username
GITHUB_OWNER=yamajid

# Repository name
GITHUB_REPO=GAMING_SITE

# =============================================================================
# OPTIONAL: Analytics & Tracking
# =============================================================================

# Google Analytics ID (for tracking visitor behavior)
# Get from: https://analytics.google.com
# Format: G-XXXXXXXXXX
GOOGLE_ANALYTICS_ID=

# Google Tag Manager Container ID (for enhanced tracking)
# Get from: https://tagmanager.google.com
# Format: GTM-XXXXXX
GTM_CONTAINER_ID=

# =============================================================================
# OPTIONAL: Deployment & Notifications
# =============================================================================

# Vercel deployment token (for auto-deployment)
VERCEL_TOKEN=

# Vercel project ID
VERCEL_PROJECT_ID=

# Webhook for Vercel deployments
VERCEL_WEBHOOK=

# =============================================================================
# OPTIONAL: Notifications
# =============================================================================

# Slack webhook for automation status notifications
SLACK_WEBHOOK=

# Discord webhook for alerts
DISCORD_WEBHOOK=

# Email webhook or service for notifications
EMAIL_WEBHOOK=

# =============================================================================
# OPTIONAL: DEBUGGING
# =============================================================================

# Enable debug logging (shows detailed operation info)
# Values: "true" or "false"
DEBUG=false

# Dry run mode (tests automation without committing/publishing)
# Values: "true" or "false"
DRY_RUN=false

# =============================================================================
# OPTIONAL: SOCIAL MEDIA
# =============================================================================

# Your Twitter account for sharing
TWITTER_ACCOUNT=@GamingCoinsHub

# Reddit credentials (if using Reddit API directly)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# =============================================================================
# HOW TO USE THIS FILE
# =============================================================================
#
# 1. Copy this file: cp automation/.env.example automation/.env.automation
# 2. Edit the file with your actual credentials
# 3. The file is automatically in .gitignore
# 4. Never commit .env.automation to GitHub!
# 5. Load during automation: source automation/.env.automation
#
# =============================================================================
# GETTING CREDENTIALS
# =============================================================================
#
# GitHub Token:
#   1. Go to https://github.com/settings/tokens
#   2. Click "Generate new token (classic)"
#   3. Select scopes: repo, workflow
#   4. Copy and paste below
#
# Claude API Key:
#   1. Go to https://console.anthropic.com/
#   2. Sign up or login
#   3. Create API key in account settings
#   4. Copy and paste below
#
# Google Analytics:
#   1. Go to https://analytics.google.com
#   2. Create property for your domain
#   3. Copy tracking ID (G-XXXXXX)
#
# =============================================================================
# SECURITY BEST PRACTICES
# =============================================================================
#
# ✅ DO:
#   - Keep .env.automation private (it's in .gitignore)
#   - Rotate tokens regularly
#   - Use least-privilege tokens (only needed permissions)
#   - Backup .env.automation securely
#
# ❌ DON'T:
#   - Commit .env.automation to git
#   - Share your tokens
#   - Use .env file in production
#   - Leave tokens in code comments
#   - Use same token for multiple purposes
#
# =============================================================================
