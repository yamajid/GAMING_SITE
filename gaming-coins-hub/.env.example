# Environment Variables for Gaming Coins Hub
# Copy this file to .env.local and fill in your actual IDs

# Google Analytics 4
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Google AdSense
GOOGLE_ADSENSE_ID=ca-pub-xxxxxxxxxxxxxxxx

# Email Service (Substack)
SUBSTACK_API_KEY=your_substack_api_key
SUBSTACK_LIST_ID=gaming-coins-hub

# Affiliate Links
AMAZON_TRACKING_ID=gamingcoinshub-20

# Site Configuration
SITE_URL=https://gamingcoinshub.com
SITE_NAME=Gaming Coins Hub

# Social Links
TWITTER_HANDLE=gamingcoinshub
REDDIT_PROFILE=gamingcoinshub
YOUTUBE_CHANNEL=gamingcoinshub

# Monetization
ENABLE_ADS=true
ENABLE_AFFILIATE=true
ENABLE_EMAIL_CAPTURE=true

#GITHUB REPO (for content management)
GITHUB_TOKEN=
